# NX-Jikkyo リバースプロキシサーバー
# Let's Encrypt の自動取得と TLS 終端を提供する

# グローバルオプション
{
	# Let's Encrypt の設定
	email tsukumizima@gmail.com

	# サーバー設定
	servers {
		# HTTP/3 は日本においては逆に遅くなるので無効化する
		# デフォルトでは利用可能な場合 HTTP/3 サーバーが有効になるので明示的な指定が必要
		protocols h1 h2

		timeouts {
			idle 86400s # アイドル 24 時間（長時間 WebSocket 対応）
			write 0s # ストリーミングを途中で切らない
		}
	}

	# サーバーログ (エラーログなど)
	# Caddy サーバー自体のログ (アクセスログは含まない)
	log {
		output file /var/log/caddy/Caddy-Server.log {
			roll_size 100mb
			roll_keep 5
			roll_keep_for 720h
		}
	}
}

# NX-Jikkyo アプリサーバー向けの共通リバースプロキシ設定
## WebSocket と通常 HTTP で同じタイムアウト・ヘルスチェックを使い、片方だけ更新漏れする状態を避ける
(nx_jikkyo_reverse_proxy_common) {
	# タイムアウト設定（長時間接続互換）
	transport http {
		keepalive 3m # Keep-Alive を有効化 (3分)
		dial_timeout 5s # 接続タイムアウト (5秒)
		response_header_timeout 86400s # レスポンスヘッダーの読み取りタイムアウト (24時間)
		read_timeout 86400s # レスポンスボディの読み取りタイムアウト (24時間)
	}

	# ヘルスチェック設定
	health_uri /api/v1/health
	health_status 2xx
	health_interval 30s
	health_timeout 5s
}

# NX-Jikkyo コンテナへのリバースプロキシ
nx-jikkyo.tsukumijima.net {
	# WebSocket はコメント配信の遅延を抑えるため、従来どおりレスポンスバッファリングを無効化する
	## 通常 HTTP まで flush_interval -1 にすると 90KB 前後の JSON も細かく flush されるため、WebSocket だけ別ルートで扱う
	@websocket {
		path_regexp ^/api/v1/channels/[^/]+/ws/[^/]+$
	}
	handle @websocket {
		# 複数ワーカーへのロードバランシング
		# メインプロセス (5610) はニコ生コメント取り込み等のバックグラウンドタスク専用とし、Caddy からは除外する
		# 5614 は通常 HTTP の第一候補にもするため、WebSocket 側では weight を半分に抑えて余力を残す
		reverse_proxy nx-jikkyo:5611 nx-jikkyo:5612 nx-jikkyo:5613 nx-jikkyo:5614 {
			# WebSocket は Python worker の CPU を強く使うため、4ワーカー全体へ分散しつつ 5614 だけ負荷を軽くする
			lb_policy weighted_round_robin 2 2 2 1

			import nx_jikkyo_reverse_proxy_common

			# ストリーミングのためにレスポンスのバッファリングを無効化
			flush_interval -1
		}
	}

	# 通常 HTTP は Caddy の標準バッファリングを使い、/api/v1/channels の大量ポーリング時の write 回数を抑える
	## 上流とタイムアウトは WebSocket ルートと同じままにして、既存 API の接続先や失敗判定を変えない
	handle {
		# 通常 HTTP 向けワーカーへのリバースプロキシ
		# メインプロセス (5610) はニコ生コメント取り込み等のバックグラウンドタスク専用とし、Caddy からは除外する
		# 5614 を第一候補にして、WebSocket を抱える 5611〜5613 へ通常 HTTP が流れ込む量を最小限にする
		reverse_proxy nx-jikkyo:5614 nx-jikkyo:5611 nx-jikkyo:5612 nx-jikkyo:5613 {
			# 通常時は 5614 を使い、ヘルスチェックで落ちた場合のみ残りのワーカーへ退避する
			lb_policy first

			import nx_jikkyo_reverse_proxy_common
		}
	}

	# アクセスログ
	# このサイトへのリクエストに関するログ
	log {
		output file /var/log/caddy/Caddy-Access.log {
			roll_size 100mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
	}
}
